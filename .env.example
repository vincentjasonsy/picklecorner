APP_NAME="Pickle Corner"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Asia/Manila
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_PH
APP_DEFAULT_CURRENCY=PHP
APP_MONEY_LOCALE=en_PH

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# File path (default below) or absolute path on a persistent disk (e.g. Render mount)
DB_DATABASE=database/database.sqlite
#
# Optional SQLite tuning (milliseconds; journal wal helps concurrent reads)
# DB_SQLITE_BUSY_TIMEOUT=5000
# DB_SQLITE_JOURNAL_MODE=wal
# DB_SQLITE_SYNCHRONOUS=NORMAL
#
# MySQL / Postgres — set DB_CONNECTION and uncomment:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Public contact form & demo requests (defaults to MAIL_FROM_ADDRESS if unset)
# CONTACT_EMAIL=team@yourdomain.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Shown on booking checkout when payment method is GCash (copy-to-clipboard)
PAYMENTS_GCASH_NUMBER=

# PayMongo (Philippines) — hosted checkout on the public venue booking page
# https://dashboard.paymongo.com — use sk_test_… / pk_test_… in development
PAYMONGO_ENABLED=true
PAYMONGO_SECRET_KEY=
# Optional: comma-separated PayMongo methods (default: gcash,qrph)
# PAYMONGO_PAYMENT_METHOD_TYPES=gcash,qrph

# When true, venue book/checkout shows optional coach selection on the review step
VENUE_BOOKING_CHECKOUT_SHOW_COACH=false

# When false, hides the public “write a review” form (approved reviews still show)
BOOKING_PUBLIC_REVIEW_FORM_ENABLED=true

# Member emails when a partner venue adds a court (same city + marketing opt-in)
BOOKING_COURT_OPENING_EMAILS=true

# Public demo signups at /try — account & member data removed after TTL (scheduler: demo:purge-expired-accounts)
DEMO_REGISTRATION_ENABLED=true
DEMO_TTL_HOURS=24

# If you ran migrate without --seed, demo users are missing. Run: php artisan db:seed
# Demo super admin: superadmin@picklecorner.ph — password: password
