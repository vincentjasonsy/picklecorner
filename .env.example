APP_NAME="Pickle Corner"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Asia/Manila
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_PH
APP_DEFAULT_CURRENCY=PHP
APP_MONEY_LOCALE=en_PH

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# File path (default below) or absolute path on a persistent disk (e.g. Render mount)
DB_DATABASE=database/database.sqlite
#
# Optional SQLite tuning (milliseconds; journal wal helps concurrent reads)
# DB_SQLITE_BUSY_TIMEOUT=5000
# DB_SQLITE_JOURNAL_MODE=wal
# DB_SQLITE_SYNCHRONOUS=NORMAL
#
# MySQL / Postgres — set DB_CONNECTION and uncomment:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
#
# Livewire file inputs (venue/court gallery, payment proofs, etc.) stage uploads on this disk first.
# Defaults to local in config/livewire.php so temp uploads still work when FILESYSTEM_DISK=s3 (S3 misconfig otherwise shows “The uploads failed to upload”).
# LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local
#
# Production: run `php artisan storage:link` so files on the public disk are served at /storage.
#
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
# Laravel Forge / cloud servers often CANNOT reach shared-hosting SMTP (e.g. cPanel mail.domain.tld:465):
# connection timeouts are common — the host may only accept SMTP from localhost, or outbound 465 is blocked.
#
# Same provider webmail outgoing (SMTP only — IMAP/POP are for inbox apps, not Laravel): try host mail.<your-domain>,
# port 587, authenticated. Example if your panel lists Outgoing mail.picklecorner.ph / SMTP 587:
# MAIL_SCHEME=null
# MAIL_HOST=mail.picklecorner.ph
# MAIL_PORT=587
# MAIL_USERNAME=support@picklecorner.ph
# MAIL_PASSWORD=mailbox-password-from-cpanel
# If this still times out from Forge, the host likely blocks remote SMTP — use Gmail/SES/Postmark instead.
#
# Reliable options from Forge: Gmail SMTP (app password), Amazon SES, Postmark, Resend — use their SMTP/API and a
# verified sender for MAIL_FROM_ADDRESS.
#
# Gmail SMTP example (Google Account → Security → 2FA → App password):
# MAIL_MAILER=smtp
# MAIL_SCHEME=null
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your.full@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# MAIL_FROM_ADDRESS="your.full@gmail.com"
#
# Optional: MAIL_MAILER=failover tries smtp then logs — avoids 500s if SMTP is down (check logs; mail may be lost).
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="support@picklecorner.ph"
MAIL_FROM_NAME="${APP_NAME}"

# Public address for privacy policy, footers, and the /contact page (mailto). Optional override:
# DATA_PRIVACY_CONTACT_EMAIL=

# Local: MAIL_MAILER=log

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Shown on booking checkout when payment method is GCash (copy-to-clipboard)
PAYMENTS_GCASH_NUMBER=

# PayMongo (Philippines) — hosted checkout on the public venue booking page
# https://dashboard.paymongo.com — use sk_test_… / pk_test_… in development
PAYMONGO_ENABLED=true
PAYMONGO_SECRET_KEY=
# Optional: comma-separated PayMongo methods (default: gcash,qrph)
# PAYMONGO_PAYMENT_METHOD_TYPES=gcash,qrph

# When true, venue book/checkout shows optional coach selection on the review step
VENUE_BOOKING_CHECKOUT_SHOW_COACH=false

# When false, hides the public “write a review” form (approved reviews still show)
BOOKING_PUBLIC_REVIEW_FORM_ENABLED=true

# When false, hides star ratings, member review panels, and landing-page review quotes site-wide (navigation skips #reviews)
BOOKING_PUBLIC_REVIEWS_ENABLED=false

# When false, hide guest-facing Register links/buttons (route remains available unless separately disabled)
BOOKING_PUBLIC_REGISTRATION_ENABLED=false

# Member emails when a partner venue adds a court (same city + marketing opt-in)
BOOKING_COURT_OPENING_EMAILS=true

# New registration alerts (admin copy) + welcome emails (to the user)
BOOKING_REGISTRATION_ALERT_EMAIL=vincent.m.sy@gmail.com

# Coach & venue portal gift cards (nav + routes). When false, only super_admin may open those pages; /admin/gift-cards unchanged
BOOKING_GIFT_CARD_MODULE_FOR_NON_SUPER_ADMINS=true

# Public demo signups at /try — account & member data removed after TTL (scheduler: demo:purge-expired-accounts)
DEMO_REGISTRATION_ENABLED=true
DEMO_TTL_HOURS=24

# If you ran migrate without --seed, demo users are missing. Run: php artisan db:seed
# Demo super admin: superadmin@picklecorner.ph — password: password
